# ============================================
# Квартира-Компаратор — Environment Variables
# ============================================

# Секретный ключ Flask (обязательно сменить в продакшене)
APP_SECRET_KEY=your-secret-key-change-me

# Пароль для доступа к приложению (если требуется)
APP_PASSWORD=

# Порт приложения
APP_PORT=5000

# Режим отладки (True/False)
APP_DEBUG=False

# Настройки парсера Avito
# Минимальная задержка между запросами (секунды)
APP_PARSER_DELAY_MIN=3

# Максимальная задержка между запросами (секунды)
APP_PARSER_DELAY_MAX=7

# Максимальное количество объявлений для парсинга
APP_PARSER_MAX_ITEMS=20
