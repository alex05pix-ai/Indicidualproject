# =========================================================
# Avito Comparator — пример переменных окружения
# Скопируйте этот файл в .env и подставьте свои значения.
# =========================================================

# --- Базовые настройки приложения ---
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# --- Город по умолчанию (slug в URL Avito) ---
APP_CITY=krasnoyarsk
APP_CITY_DISPLAY=Красноярск

# --- База данных ---
# SQLite (по умолчанию для разработки):
APP_DATABASE_URL=sqlite:///data/app.db
# PostgreSQL пример (для продакшна):
# APP_DATABASE_URL=postgresql+psycopg2://user:password@db:5432/avito_comparator

# --- Безопасность ---
# Если задан, включается HTTP Basic Auth с этим паролем (логин: admin)
APP_PASSWORD=
APP_BASIC_AUTH_USER=admin

# --- Парсер Avito ---
# Минимальная и максимальная задержка между действиями (сек.)
APP_DELAY_MIN=2.0
APP_DELAY_MAX=5.0
# Задержка между страницами выдачи (сек.)
APP_PAGE_DELAY_MIN=10.0
APP_PAGE_DELAY_MAX=20.0
# Лимит страниц поиска и общий лимит карточек
APP_MAX_PAGES=5
APP_MAX_LISTINGS=20
# Headless-режим браузера
APP_HEADLESS=true
# Путь к файлу с куками (опционально, JSON)
APP_COOKIES_FILE=
# Таймаут на одну страницу (мс.)
APP_PAGE_TIMEOUT_MS=30000

# --- Геокодер ---
APP_NOMINATIM_USER_AGENT=avito-comparator/1.0 (contact@example.com)
APP_GEOCODE_TIMEOUT=10

# --- Деплой / домен ---
# Если задан, используется в Nginx и для CSP/cookies.
DOMAIN_NAME=
# E-mail для Let's Encrypt
LETSENCRYPT_EMAIL=

# --- Кэширование результатов сравнения (часы) ---
APP_SHARE_TTL_HOURS=24
APP_HISTORY_LIMIT=10
