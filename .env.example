# ============================================
# Конфигурация приложения "Квартира-Компаратор"
# ============================================
# Скопируйте этот файл в .env и заполните значения

# === Основные настройки ===
APP_SECRET_KEY=your-secret-key-here-change-in-production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=5000

# === Домен и доступ ===
# Если задано — приложение будет настроено на этот домен (для SSL и Nginx)
# DOMAIN_NAME=your-domain.com

# Пароль для доступа к приложению (HTTP Basic Auth)
# Если не задан — приложение открыто для всех
# APP_PASSWORD=your-secure-password

# === База данных ===
# SQLite (по умолчанию, хорошо для локальной разработки):
# APP_DATABASE_URL=sqlite:///data/app.db
# PostgreSQL (для продакшна):
# APP_DATABASE_URL=postgresql://user:password@localhost:5432/kvartira_db

# === Город и геокодирование ===
APP_CITY=Красноярск
APP_CITY_LAT=56.0153
APP_CITY_LON=92.8932
APP_NOMINATIM_USER_AGENT=kvartira-comparator/1.0
# Время жизни кеша геокодирования (секунды), по умолчанию 24 часа
APP_GEOCODE_CACHE_TTL=86400

# === Парсер Avito ===
# Задержки между действиями (секунды) — для обхода защиты
APP_PARSER_MIN_DELAY=2.0
APP_PARSER_MAX_DELAY=5.0
# Задержки между страницами (секунды)
APP_PARSER_PAGE_DELAY_MIN=10.0
APP_PARSER_PAGE_DELAY_MAX=20.0
# Максимум страниц пагинации
APP_PARSER_MAX_PAGES=5
# Максимум аналогов для сбора
APP_PARSER_MAX_ANALOGS=20
# Таймаут загрузки страницы (мс)
APP_PARSER_TIMEOUT=60000
# Путь к файлу куки (опционально, для обхода защиты)
# APP_PARSER_COOKIES_FILE=cookies.json

# === Фильтры по умолчанию ===
# Допуск по площади (15% = 0.15)
APP_DEFAULT_AREA_TOLERANCE=0.15
# Максимальное расстояние поиска (км)
APP_DEFAULT_MAX_DISTANCE_KM=2.0
# Глубина поиска (количество аналогов)
APP_DEFAULT_SEARCH_DEPTH=10

# === Кеширование ===
# Время жизни кеша результатов (секунды), по умолчанию 1 час
APP_CACHE_TTL=3600
# Время жизни публичных ссылок (секунды), по умолчанию 24 часа
APP_SHARE_LINK_TTL=86400

# === Логирование ===
# Уровень: DEBUG, INFO, WARNING, ERROR
APP_LOG_LEVEL=INFO
# Файл лога (опционально, по умолчанию только stdout)
# APP_LOG_FILE=/var/log/kvartira/app.log
